<%- include('partials/header', { title: 'SecureAuth - Home' }) %>

<div class="hero">
  <div class="hero-content">
    <div class="hero-icon">🔐</div>
    <h1>Secure User Authentication</h1>
    <p>A complete authentication system with secure login, registration, session management, password hashing, and role-based access control.</p>
    <div class="hero-buttons">
      <a href="/auth/register" class="btn btn-primary">Get Started</a>
      <a href="/auth/login" class="btn btn-outline">Login</a>
    </div>
    <div class="features">
      <div class="feature-card">
        <span>🔒</span>
        <h3>Password Hashing</h3>
        <p>bcrypt with salt rounds for secure password storage</p>
      </div>
      <div class="feature-card">
        <span>🎫</span>
        <h3>Session Management</h3>
        <p>Secure HTTP-only cookie sessions via express-session</p>
      </div>
      <div class="feature-card">
        <span>🛡️</span>
        <h3>Protected Routes</h3>
        <p>Middleware-guarded routes accessible only after login</p>
      </div>
      <div class="feature-card">
        <span>👑</span>
        <h3>Role-Based Access</h3>
        <p>User & Admin roles with different access levels</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
