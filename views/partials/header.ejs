<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'SecureAuth' %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-brand">🔐 SecureAuth</a>
      <div class="nav-links">
        <% if (user) { %>
          <a href="/dashboard">Dashboard</a>
          <a href="/dashboard/profile">Profile</a>
          <% if (user.role === 'admin') { %>
            <a href="/dashboard/admin">Admin Panel</a>
          <% } %>
          <a href="/auth/logout" class="btn-logout">Logout</a>
        <% } else { %>
          <a href="/auth/login">Login</a>
          <a href="/auth/register" class="btn-register">Register</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success_msg %></div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
